# =============================================================================
# @shooteger/nuxt-stripe  —  Environment variable template
# =============================================================================
# Copy this file to `.env` and replace the placeholders with your own keys.
# Both can be obtained from the Stripe Dashboard → Developers → API keys.
#
# IMPORTANT:
#   - Test keys start with `sk_test_` / `pk_test_`
#   - Live  keys start with `sk_live_` / `pk_live_`
#   - Never commit real keys to version control.
# =============================================================================

# Server-side secret key — used by `useServerStripe()` to initialise the
# Stripe Node.js SDK. Required for any server API route that talks to Stripe.
NUXT_STRIPE_SECRET_KEY=sk_test_...

# Client-side publishable key — used by `useClientStripe()` to initialise
# Stripe.js in the browser. Required for Stripe Elements / Checkout on the
# front-end.
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
